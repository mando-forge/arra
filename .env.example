# Supabase Configuration
# You can find these in your Supabase Project Settings -> API
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Configure OPENROUTER_API_KEY as a Supabase Edge Function secret.
# Never expose it through a VITE_ browser environment variable.
# Also configure these Edge Function secrets:
# ALLOWED_ORIGINS="https://arra.tech,https://www.arra.tech"
# SUPABASE_SERVICE_ROLE_KEY="configured by Supabase for Edge Functions"
# CHAT_MODEL="nvidia/nemotron-3-ultra-550b-a55b:free"
# CHAT_FALLBACK_MODEL="openai/gpt-oss-120b:free"
#
# Admin users must have app_metadata.role set to "admin". User-editable metadata
# is intentionally not accepted for authorization.
